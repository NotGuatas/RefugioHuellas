@{
    ViewData["Title"] = "Sincronizar con EscaladaEC";
}

<div class="container mt-4">
    <h2>Sincronización con EscaladaEC</h2>
    <p class="text-muted">Datos cifrados con AWS KMS y enviados vía Keycloak Bearer token.</p>

    @if (ViewBag.Respuesta != null)
    {
        <div class="card mt-3">
            <div class="card-header bg-success text-white">
                Respuesta de EscaladaEC
            </div>
            <div class="card-body">
                <pre><code>@ViewBag.Respuesta</code></pre>
            </div>
        </div>
    }
</div>
