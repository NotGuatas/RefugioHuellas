<ul class="navbar-nav ms-auto">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <li class="nav-item">
            <span class="nav-link">@User.Identity.Name</span>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="/logout">Salir</a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" href="/login">Ingresar</a>
        </li>
    }
</ul>
